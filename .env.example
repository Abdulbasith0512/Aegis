# ==============================================================================
# AegisAI Environment Configuration - Example Template
# ==============================================================================

# Global Configurations
ENVIRONMENT=development
LOG_LEVEL=info
SECRET_KEY=generate_a_secure_hex_key_here_for_jwt_auth

# API Gateway Settings
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_password
DB_NAME=aegisai_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres_password@localhost:5432/aegisai_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Neo4j Graph Database Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password
NEO4J_AUTH=neo4j/neo4j_password

# Qdrant Vector Database Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333

# LLM & Third-Party Service Credentials (Placeholders)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
HUGGINGFACE_API_TOKEN=your_huggingface_token_here

# Observability and Telemetry Configuration
GRAFANA_PASSWORD=grafana_password
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Security Auditing & Governance
HUMAN_REVIEW_THRESHOLD=75
TRUST_SCORE_MIN_THRESHOLD=50
Compliance_Mode=strict
